{
  "name": "icss-lang",
  "publisher": "jgermade",
  "displayName": "Indented CSS",
  "description": "Syntax highlighting for the Indented CSS language (.icss - .cssi)",
  "repository": "https://github.com/icss-lang/icss-lang",
  "icon": "icons/png/icon_256.png",
  "version": "0.1.5",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "icss",
        "aliases": [
          "Indented CSS",
          "icss"
        ],
        "extensions": [
          ".icss",
          ".cssi"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/icss-new.svg",
          "dark": "./icons/icss-new.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "icss",
        "scopeName": "source.icss",
        "path": "./syntaxes/icss.tmLanguage.json"
      },
      {
        "scopeName": "source.icss.injection",
        "path": "./syntaxes/icss.injection.tmLanguage.json",
        "injectTo": [
          "source.js",
          "source.jsx",
          "source.ts",
          "source.tsx"
        ]
      },
      {
        "scopeName": "source.icss.html.injection",
        "path": "./syntaxes/icss.html.injection.tmLanguage.json",
        "injectTo": [
          "text.html.basic",
          "text.html.vue",
          "source.svelte"
        ],
        "embeddedLanguages": {
          "source.icss": "icss"
        }
      }
    ]
  }
}