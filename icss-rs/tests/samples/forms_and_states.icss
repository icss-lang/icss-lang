.form-group, .input-group
  margin-bottom: 1.5rem
  position: relative

  input[type="text"], input[type="password"]
    width: 100%
    padding: 10px
    border: 1px solid #ccc
    border-radius: 4px

    &:focus
      border-color: #007bff
      outline: none

      + .input-icon
        color: #007bff

  .input-icon
    position: absolute
    right: 10px
    top: 50%
    transform: translateY(-50%)
    color: #888

.btn-primary
  background: #007bff
  color: #fff
  border: none
  padding: 10px 20px
  cursor: pointer

  &:disabled
    background: #ccc
    cursor: not-allowed
