.header
  background-color: #333
  color: white
  padding: 1rem

  .logo
    font-size: 2rem
    font-weight: bold

  .nav
    display: flex
    gap: 15px

    a
      color: lightgray
      text-decoration: none

      &:hover
        color: white
        text-decoration: underline

@media (max-width: 768px)
  .header
    flex-direction: column
    padding: 0.5rem

    .nav
      flex-direction: column
      gap: 5px
